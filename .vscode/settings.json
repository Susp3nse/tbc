{
  // --- General Editor ---
  "editor.insertSpaces": true,
  "editor.trimAutoWhitespace": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.eol": "\n",

  // --- Per-Language Indentation ---
  "[lua]": {
    "editor.tabSize": 3
  },
  "[javascript]": {
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.tabSize": 2
  },
  "[astro]": {
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.tabSize": 2
  },
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },

  // --- File Associations ---
  "files.associations": {
    "*.lua": "lua"
  },

  // --- Search Exclusions ---
  "search.exclude": {
    "**/node_modules": true,
    "**/TBC-main": true,
    "**/Addon Libraries": true,
    "apps/tbc-rotation/output": true,
    "**/dist": true
  },
  "files.exclude": {
    "**/node_modules": true
  },

  // --- Lua Language Server ---
  "Lua.workspace.library": [
    "${workspaceFolder}/docs/api",
    "~/.vscode/extensions/ketho.wow-api-0.22.3/Annotations/Core"
  ],
  "Lua.runtime.version": "Lua 5.1",
  "Lua.diagnostics.globals": [
    "GetNumRaidMembers",
    "GetNumPartyMembers",
    "IsSpellKnown",
    "IsSpellInRange",
    "UIParent",
    "UISpecialFrames",
    "Minimap",
    "GameTooltip",
    "GameTooltip_Hide",
    "SlashCmdList",
    "SLASH_MENAGERIELOG1",
    "SLASH_MENAGERIELOG2",
    "SLASH_MENAGERIE1",
    "SLASH_MENAGERIE2",
    "RAID_CLASS_COLORS",
    "INVSLOT_HEAD",
    "TMW",
    "Toaster",
    "LibStub",
    "Action",
    "DEFAULT_CHAT_FRAME",
    "ScrollingEdit_OnTextChanged"
  ],
  "Lua.diagnostics.disable": [
    "lowercase-global",
    "inject-field",
    "undefined-field",
    "redefined-local",
    "need-check-nil"
  ],
  "stylua.targetReleaseVersion": "latest",
  "Lua.runtime.builtin": {
    "basic": "disable",
    "debug": "disable",
    "io": "disable",
    "math": "disable",
    "os": "disable",
    "package": "disable",
    "string": "disable",
    "table": "disable",
    "utf8": "disable"
  },
  "Lua.type.weakUnionCheck": true
}
