{
  "name": "gg-rotations",
  "private": true,
  "scripts": {
    "build:rotation": "corepack pnpm --filter @flux/tbc-rotation build",
    "build:rotation:sync": "corepack pnpm --filter @flux/tbc-rotation watch:log",
    "build:website": "corepack pnpm --filter @flux/website build",
    "build:bot": "corepack pnpm --filter @flux/bot build",
    "release": "tsx tooling/release.ts",
    "release:publish": "tsx tooling/publish.ts",
    "lint": "corepack pnpm exec oxlint apps packages tooling --deny-warnings",
    "lint:fix": "corepack pnpm exec oxlint apps packages tooling --fix",
    "format": "corepack pnpm exec oxfmt apps packages tooling",
    "format:check": "corepack pnpm exec oxfmt --check apps packages tooling",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "check": "corepack pnpm run lint && corepack pnpm run format:check && corepack pnpm run typecheck",
    "test": "corepack pnpm -r --if-present test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "0.54.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,js,mjs,cjs}": [
      "oxlint --fix --deny-warnings",
      "oxfmt"
    ],
    "*.{json,jsonc}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.6.0"
}
