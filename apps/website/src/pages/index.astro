---
import Base from '../layouts/Base.astro';
import Crest from '../components/Crest.astro';
import CodexEntry from '../components/CodexEntry.astro';
import Rule from '../components/Rule.astro';
import { config, url } from '../config';

const bestiary = [
  { slug: 'druid', name: 'Druid', color: 'druid', blurb: 'Cat, Bear, Moonkin, Tree — powershifting and form-aware to the claw.' },
  { slug: 'hunter', name: 'Hunter', color: 'hunter', blurb: 'Shot weaving, clip tracking, and a pet that knows when to strike.' },
  { slug: 'mage', name: 'Mage', color: 'mage', blurb: 'Fire, Frost, Arcane — burn phases and scorch debuffs, conserved on cue.' },
  { slug: 'paladin', name: 'Paladin', color: 'paladin', blurb: 'Seal twisting, off-GCD Judgements, and healing that reads the party.' },
  { slug: 'priest', name: 'Priest', color: 'priest', blurb: 'Shadow, Smite, Holy, Discipline — DoTs woven with shielded prevention.' },
  { slug: 'rogue', name: 'Rogue', color: 'rogue', blurb: 'Combo points, poisons, stealth openers, and energy pooled to the edge.' },
  { slug: 'shaman', name: 'Shaman', color: 'shaman', blurb: 'Totem twisting, shock rotations, and smart party healing on tap.' },
  { slug: 'warlock', name: 'Warlock', color: 'warlock', blurb: 'DoTs, curses, Life Tap, and a demon kept on a short leash.' },
  { slug: 'warrior', name: 'Warrior', color: 'warrior', blurb: 'Stance-aware rage, Heroic Strike queuing, and Sunder kept stacked.' },
];
---

<Base title="Home">
  <header class="hero">
    <div class="ring"><div class="ring-spin"></div></div>
    <div class="hero-content">
      <div class="eyebrow">A Bestiary of Rotations</div>
      <h1>MENAGERIE</h1>
      <p class="tagline">Nine classes. <em>One intelligence.</em></p>
      <div class="btn-group">
        <a href={config.downloadUrl} class="btn btn-primary">&#8595; Download Latest</a>
        <a href={url('/guides/installation')} class="btn btn-secondary">Installation Guide</a>
      </div>
      <div class="statline"><b>9</b> classes &nbsp;&middot;&nbsp; <b>25</b> specs &nbsp;&middot;&nbsp; priority-driven</div>
    </div>
  </header>

  <Rule />

  <section class="band" id="bestiary">
    <div class="section-head">
      <span class="kicker">The Bestiary</span>
      <h2>Nine specimens, each its own intelligence</h2>
      <p>Every class is fully tamed — complete rotation logic, configurable per spec. Choose your creature.</p>
    </div>
    <div class="crest-grid">
      {bestiary.map((c) => <Crest slug={c.slug} name={c.name} color={c.color} blurb={c.blurb} />)}
    </div>
  </section>

  <Rule />

  <section class="band">
    <div class="section-head">
      <span class="kicker">Inscribed Behaviors</span>
      <h2>What every specimen knows</h2>
    </div>
    <div class="entries">
      <CodexEntry glyph="✦" title="Smart Rotations">
        A priority-based strategy system that adapts to your form, resources, target state, and group composition in real time — not a fixed macro.
      </CodexEntry>
      <CodexEntry glyph="❖" title="Form-Aware">
        Respects your current form in combat — no unwanted shifting. A suggestion icon appears only when a form change would actually help.
      </CodexEntry>
      <CodexEntry glyph="◈" title="Resource Management">
        Energy pooling, rage gating, mana-conservation tiers, and powershift optimization with Wolfshead detection. It spends when it counts.
      </CodexEntry>
      <CodexEntry glyph="✶" title="Consumable Automation">
        Healthstones, healing and mana potions, and Dark Runes fire at configurable thresholds — form-aware and reagent-safe.
      </CodexEntry>
    </div>
  </section>

  <Rule />

  <section class="band">
    <div class="proof">
      <div>
        <span class="kicker">In the Field</span>
        <h2>Watch it think, frame by frame</h2>
        <p>The context object is rebuilt every frame — player state, target, positioning, settings — and the highest-priority action lights up. Recovery, cooldowns, and self-buffs run on a middleware layer beneath your rotation.</p>
        <p style="color: var(--vellum-faint); font-size: 0.82rem;">A live readout of the engine choosing your next action.</p>
      </div>
      <div class="hud">
        <div class="hud-bar">
          <span class="dot"></span>
          <span>menagerie &middot; druid / feral</span>
          <span class="build">build #482</span>
        </div>
        <div class="hud-row active">
          <span class="lhs"><span class="pip">&#9654;</span> Mangle</span>
          <span class="tag">cast &middot; primary</span>
        </div>
        <div class="hud-row">
          <span class="lhs"><span class="pip">&#8635;</span> Savage Roar</span>
          <span class="tag">12.4s left</span>
        </div>
        <div class="hud-row">
          <span class="lhs"><span class="pip">&#8987;</span> Pool Energy</span>
          <span class="meter"><i style="width: 64%;"></i></span>
        </div>
        <div class="hud-row">
          <span class="lhs"><span class="pip">&#10010;</span> Healthstone</span>
          <span class="tag">&le; 35% hp</span>
        </div>
      </div>
    </div>
  </section>

  <Rule />

  <section class="band">
    <div style="max-width: 760px; margin: 0 auto; text-align: center;">
      <span class="kicker">Beneath the Ink</span>
      <h2 style="font-size: clamp(1.5rem, 4vw, 2.1rem); border: none; padding: 0; margin-bottom: 1rem;">A modular strategy registry</h2>
      <p style="color: var(--vellum-dim); font-size: 1rem;">Built on the GGL Action framework. A middleware layer handles recovery, cooldowns, self-buffs, and dispels across every spec; playstyle strategies execute in priority order; and one schema generates the settings UI, backing store, and cached runtime access.</p>
      <div class="pipeline">
        <span class="pill"><b>middleware</b></span>
        <span class="arrow">&rarr;</span>
        <span class="pill"><b>strategies</b></span>
        <span class="arrow">&rarr;</span>
        <span class="pill"><b>context</b> / frame</span>
      </div>
    </div>
  </section>
</Base>
