{
  // Cloudflare Worker that serves the built Astro site as static assets.
  // Assets-only Worker (no `main`): Cloudflare serves ./dist directly.
  "name": "menagerie-website",
  "compatibility_date": "2026-06-15",
  "assets": {
    // Relative to this config file → apps/website/dist
    "directory": "./dist",
    // Serve dist/404.html for unmatched routes if Astro emits one.
    "not_found_handling": "404-page",
  },
}
