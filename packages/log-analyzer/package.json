{
  "name": "@flux/log-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.ts"
    },
    "./compare": {
      "types": "./src/index.d.ts",
      "import": "./src/compare.ts"
    },
    "./process-fight": {
      "types": "./src/index.d.ts",
